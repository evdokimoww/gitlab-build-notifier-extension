{
  "manifest_version": 3,
  "name": "GitLab build stage notifier",
  "version": "1.0.6",
  "description": "Уведомления об окончании stage в GitLab по открытым вкладкам MR/пайплайна",
  "icons": {
    "16": "icons/extension-16.png",
    "32": "icons/extension-32.png",
    "48": "icons/extension-48.png",
    "128": "icons/extension-128.png"
  },
  "permissions": ["tabs", "storage", "notifications", "alarms", "scripting", "offscreen"],
  "host_permissions": [],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "GitLab CI: статус",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/extension-16.png",
      "32": "icons/extension-32.png",
      "48": "icons/extension-48.png",
      "128": "icons/extension-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
