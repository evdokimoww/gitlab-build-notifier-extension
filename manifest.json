{
  "manifest_version": 3,
  "name": "GitLab build stage notifier",
  "version": "1.0.1",
  "description": "Уведомления об окончании stage в GitLab по открытым вкладкам MR/пайплайна",
  "icons": {
    "128": "icons/notify-ok.png"
  },
  "permissions": ["tabs", "storage", "notifications", "alarms", "scripting", "offscreen"],
  "host_permissions": ["https://git-02.t1-group.ru/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "GitLab CI: статус",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/notify-ok.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
